{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.agents/hooks/scripts/check-harness.mjs\"",
            "timeout": 30,
            "statusMessage": "Checking harness files"
          }
        ]
      }
    ]
  }
}
